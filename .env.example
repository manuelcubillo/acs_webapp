# DB client driver: "neon" (Neon's HTTP proxy) or "local" (node-postgres,
# for a regular Postgres such as the Dockerized local DB). Defaults to "neon".
DB_DRIVER=
DATABASE_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
NEXT_PUBLIC_BETTER_AUTH_URL=
RESEND_APIKEY=
RESEND_FROM_EMAIL=

# ─── Cron / scheduled jobs ──────────────────────────────────────────────────
# Shared secret protecting the daily retention purge endpoint
# (/api/cron/purge-archived). The caller must send
# `Authorization: Bearer <CRON_SECRET>`. On Vercel, Cron Jobs inject this header
# automatically when CRON_SECRET is set in the project env. On Docker /
# self-hosted, the host/container cron must send it once a day (see
# docs/context/modules/infrastructure.md). If unset, the endpoint refuses every
# request (fail closed). Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── Photo storage (S3-compatible) ──────────────────────────────────────────
# Driver: "r2" for Cloudflare R2 in production, "minio" for local/self-hosted.
STORAGE_DRIVER=
# S3 endpoint URL (R2: https://<account>.r2.cloudflarestorage.com  |  MinIO: http://localhost:9000).
S3_ENDPOINT=
# R2 uses "auto"; MinIO accepts any region string (e.g. "us-east-1").
S3_REGION=auto
# Bucket name.
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# "true" for MinIO (path-style URLs), "false" for R2 (virtual-host style).
S3_FORCE_PATH_STYLE=false
