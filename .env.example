DATABASE_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
NEXT_PUBLIC_BETTER_AUTH_URL=
RESEND_APIKEY=
RESEND_FROM_EMAIL=

# ─── Photo storage (S3-compatible) ──────────────────────────────────────────
# Driver: "r2" for Cloudflare R2 in production, "minio" for local/self-hosted.
STORAGE_DRIVER=
# S3 endpoint URL (R2: https://<account>.r2.cloudflarestorage.com  |  MinIO: http://localhost:9000).
S3_ENDPOINT=
# R2 uses "auto"; MinIO accepts any region string (e.g. "us-east-1").
S3_REGION=auto
# Bucket name.
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# "true" for MinIO (path-style URLs), "false" for R2 (virtual-host style).
S3_FORCE_PATH_STYLE=false
