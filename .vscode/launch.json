{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Vercel: Debug Server-side",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "skipFiles": ["<node_internals>/**"],
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "- Local:\\s+(https?://localhost:\\d+)",
        "uriFormat": "%s"
      }
    },
    {
      "name": "Vercel: Debug Client-side",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Vercel: Full Stack (Server & Client)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "skipFiles": ["<node_internals>/**"],
      "serverReadyAction": {
        "action": "debugWithChrome",
        "pattern": "- Local:\\s+(https?://localhost:\\d+)",
        "webRoot": "${workspaceFolder}"
      }
    }
  ]
}