### `src/lib/api/errors.ts`\
```typescript\
class AppError extends Error \{ constructor(message, code, httpStatus = 500) \}\
class AuthenticationError extends AppError  // 401, code: "UNAUTHENTICATED"\
class AuthorizationError extends AppError   // 403, code: "UNAUTHORIZED"\
class UnprocessableError extends AppError   // 422, code: "UNPROCESSABLE"\
\
type ActionResult<T> =\
  | \{ success: true; data: T \}\
  | \{ success: false; error: string; code?: string; fieldErrors?: Record<string, string[]> \}\
```\
